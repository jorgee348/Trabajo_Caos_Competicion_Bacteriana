{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar proyecto",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-Wall", "-Wextra", "-g",
        "${workspaceFolder}/main.c",
        "${workspaceFolder}/funciones_auxiliares.c",
        "${workspaceFolder}/genera_redes.c",
        "${workspaceFolder}/dinamica.c",
        "-o", "${workspaceFolder}/programa",
        "-lm"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Ejecutar proyecto",
      "type": "shell",
      "command": "${workspaceFolder}/programa",
      "dependsOn": "Compilar proyecto",
      "problemMatcher": []
    },
    {
      "label": "Build & Run",
      "dependsOn": [
        "Compilar proyecto",
        "Ejecutar proyecto"
      ],
      "dependsOrder": "sequence",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}